{
    "name": "@marceloglacial/snow-wind",
    "version": "1.0.0",
    "author": "Marcelo Glacial",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "yarn eslint && yarn format && next build",
        "start": "next start",
        "lint": "next lint",
        "format": "prettier -w pages",
        "eslint": "eslint --fix pages/*.ts*",
        "husky-actions": "npm run format && npm run lint",
        "prepare": "husky install",
        "test": "concurrently \"yarn dev\" \"yarn run cypress open\"",
        "test:ci": "next build && concurrently \"yarn start\" \"cypress run --headless\""
    },
    "dependencies": {
        "@marceloglacial/brinca-ui": "^1.2.2",
        "@next/font": "13.4.19",
        "@types/node": "20.5.9",
        "@types/react": "18.2.21",
        "@types/react-dom": "18.2.7",
        "aos": "^2.3.4",
        "eslint": "8.48.0",
        "eslint-config-next": "13.4.19",
        "next": "13.4.19",
        "react": "18.2.0",
        "react-dom": "18.2.0",
        "typescript": "5.2.2"
    },
    "devDependencies": {
        "@types/aos": "^3.0.4",
        "@typescript-eslint/eslint-plugin": "^6.6.0",
        "@typescript-eslint/parser": "^6.6.0",
        "autoprefixer": "^10.4.15",
        "concurrently": "^8.2.1",
        "cypress": "^13.1.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "husky": "^8.0.3",
        "postcss": "^8.4.29",
        "prettier": "^3.0.3",
        "tailwindcss": "^3.3.3"
    }
}
